#include <stdio.h>
#include <string.h>
#include <sys/ipc.h>
#include <sys/msg.h>
#include <unistd.h>
#include <sys/wait.h>

struct msg_buffer {
    long msg_type;
    char msg_text[100];
};

int main() {
    struct msg_buffer message, msg;
    char rev[100];

    int msgid = msgget((key_t)1234, 0666 | IPC_CREAT);

    pid_t pid = fork();

    if (pid > 0) {   // Parent
        char str[100];

        printf("Enter a string: ");
        scanf("%s", str);

        message.msg_type = 1;
        strcpy(message.msg_text, str);

        msgsnd(msgid, &message, sizeof(message.msg_text), 0);

        wait(NULL);

        msgrcv(msgid, &message, sizeof(message.msg_text), 2, 0);

        printf("Reversed: %s\n", message.msg_text);

        if (strcmp(str, message.msg_text) == 0)
            printf("Palindrome\n");
        else
            printf("Not Palindrome\n");

        msgctl(msgid, IPC_RMID, NULL);
    }
    else {          // Child
        msgrcv(msgid, &msg, sizeof(msg.msg_text), 1, 0);

        int len = strlen(msg.msg_text);

        for (int i = 0, j = len - 1; i < len; i++, j--)
            rev[i] = msg.msg_text[j];

        rev[len] = '\0';

        message.msg_type = 2;
        strcpy(message.msg_text, rev);

        msgsnd(msgid, &message, sizeof(message.msg_text), 0);
    }

    return 0;
}
