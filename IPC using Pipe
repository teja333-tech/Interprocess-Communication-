#include <stdio.h>
#include <unistd.h>
#include <math.h>
#include <sys/types.h>
#include <sys/wait.h>

int main() {
    int p1[2], p2[2];
    float a, b, c, child_result;

    pipe(p1);
    pipe(p2);

    printf("Enter a, b, c: ");
    scanf("%f %f %f", &a, &b, &c);

    pid_t pid = fork();

    if (pid > 0) {   // Parent
        close(p1[0]);
        close(p2[1]);

        write(p1[1], &a, sizeof(a));
        write(p1[1], &b, sizeof(b));
        write(p1[1], &c, sizeof(c));

        read(p2[0], &child_result, sizeof(child_result));

        float result = sqrt(b * b - child_result);
        printf("Final Result = %f\n", result);

        wait(NULL);
    }
    else {          // Child
        close(p1[1]);
        close(p2[0]);

        float a1, b1, c1;

        read(p1[0], &a1, sizeof(a1));
        read(p1[0], &b1, sizeof(b1));
        read(p1[0], &c1, sizeof(c1));

        float r = 4 * a1 * c1;

        write(p2[1], &r, sizeof(r));
    }

    return 0;
}
